  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Crear cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('cliente_id', data.id);",
                  "",
                  "pm.test('Cliente creado con nombre y direccion', function () {",
                  "    pm.expect(data).to.have.property('nombre');",
                  "    pm.expect(data).to.have.property('direccion');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"direccion\": \"Av. Principal 123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/clientes/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "clientes",
                ""
              ]
            }
          }
        },
        {
          "name": "Listar clientes",
          "event": [
            {
              "listen": "test",
              "script": {
